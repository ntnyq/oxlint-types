{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "js/ts.experimental.useTsgo": true,
  "cSpell.words": [
    "bumpp",
    "esbuild",
    "esmodule",
    "Hrefs",
    "misrefactored",
    "oxfmt",
    "oxlint",
    "polyfillio",
    "Serde",
    "Shinigami",
    "tsgo"
  ],
  "cSpell.allowCompoundWords": true
}
