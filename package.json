{
  "name": "@oxlint-types/define-config",
  "type": "module",
  "version": "0.0.3",
  "packageManager": "pnpm@11.1.2",
  "description": "Strong typed `defineConfig` function support for oxlint.",
  "keywords": [
    "oxlint",
    "define-config",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "homepage": "https://github.com/ntnyq/oxlint-types#readme",
  "repository": "ntnyq/oxlint-types",
  "bugs": {
    "url": "https://github.com/ntnyq/oxlint-types/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "rules:generate": "tsx ./scripts/generate-rules.ts && pnpm run format",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@ntnyq/tsconfig": "^3.1.0",
    "@types/node": "^25.8.0",
    "@typescript/native-preview": "^7.0.0-dev.20260517.1",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.1",
    "vitest": "^4.1.6"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx,vue}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
